{
  "name": "ttg-core-app",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "nuxt dev --host --no-qr",
    "build": "nuxt build",
    "preview": "nuxt preview",
    "server": "node .output/server/index.mjs",
    "postinstall": "nuxt cleanup && nuxt prepare",
    "type-check": "vue-tsc -p tsconfig.json",
    "lint:check": "eslint .",
    "lint:write": "eslint . --fix",
    "lint:workflow": "eslint . --quiet",
    "stylelint:check": "stylelint \"{**/*,*}.{css,scss,vue}\" --ignore-path .gitignore",
    "stylelint:write": "stylelint \"{**/*,*}.{css,scss,vue}\" --ignore-path .gitignore --fix",
    "stylelint:workflow": "stylelint \"{**/*,*}.{css,scss,vue}\" --ignore-path .gitignore --quiet",
    "prepare": "pnpm simple-git-hooks"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1008.0",
    "@faker-js/faker": "^10.3.0",
    "@iconify-json/tabler": "^1.2.31",
    "@jsquash/webp": "^1.5.0",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/icon": "^2.2.1",
    "@nuxt/image": "^2.0.0",
    "@nuxt/ui": "^4.5.1",
    "@nuxtjs/device": "^4.0.0",
    "@nuxtjs/seo": "^3.4.0",
    "@pinia/nuxt": "^0.11.3",
    "@tanstack/vue-table": "^8.21.3",
    "@ttg-club/dice-roller-parser": "^0.3.2",
    "@vueuse/core": "^14.2.1",
    "@vueuse/gesture": "^2.0.0",
    "@vueuse/integrations": "^14.2.1",
    "@vueuse/math": "^14.2.1",
    "@vueuse/nuxt": "^14.2.1",
    "bytes": "^3.1.2",
    "colorjs.io": "^0.6.1",
    "dayjs": "^1.11.20",
    "dexie": "^4.3.0",
    "es-toolkit": "^1.45.1",
    "http-status-codes": "^2.3.0",
    "idb-keyval": "^6.2.2",
    "jose": "^6.2.1",
    "js-base64": "^3.7.8",
    "lg-fullscreen": "^1.2.1",
    "lg-thumbnail": "^1.2.1",
    "lg-zoom": "^1.3.0",
    "lightgallery": "2.9.0",
    "mime": "^4.1.0",
    "motion": "^12.36.0",
    "ms": "^2.1.3",
    "nuxt": "^4.4.2",
    "nuxt-security": "^2.5.1",
    "pako": "^2.1.0",
    "pinia": "^3.0.4",
    "sharp": "^0.34.5",
    "stopword": "^3.1.5",
    "transliteration": "^2.6.1",
    "uuid": "^13.0.0",
    "valibot": "1.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "@nuxtjs/stylelint-module": "^5.2.1",
    "@prettier/plugin-oxc": "^0.1.3",
    "@svifty7/eslint-config": "^0.0.11",
    "@types/bytes": "^3.1.5",
    "@types/ms": "^2.1.0",
    "@types/pako": "^2.0.4",
    "@types/stopword": "^2.0.3",
    "eslint": "^9.39.3",
    "lint-staged": "^16.3.3",
    "postcss-html": "^1.8.1",
    "postcss-scss": "^4.0.9",
    "sass-embedded": "^1.98.0",
    "simple-git-hooks": "^2.13.1",
    "stylelint-config-clean-order": "^8.0.1",
    "typescript": "^5.9.3",
    "vue-tsc": "^3.2.5"
